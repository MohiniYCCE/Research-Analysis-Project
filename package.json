{
  "scripts": {
    "dev:install": "pnpm install && cd artifacts/streamlit-app && pip install -r requirements.txt",
    "dev": "concurrently \"pnpm --filter @workspace/api-server run dev\" \"pnpm --filter @workspace/statyx-ai run dev\" \"cd artifacts/streamlit-app && python -m streamlit run app.py --server.port=8501 --server.headless=true --server.enableCORS=false --server.enableXsrfProtection=false\"
  },
  "devDependencies": {
    "concurrently": "^7.0.0"
  }
}